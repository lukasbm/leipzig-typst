// Font family and sizes for the Leipzig theme.
//
// All sizes are taken verbatim from the corporate-design SPEC. The base text
// is Arial (Liberation Sans as a metric-compatible fallback) and every block
// uses single line spacing ("Zeilenabstand einfach").

#let font-family = ("Arial", "Liberation Sans")

// single line spacing
#let line-leading = 0.65em

// Haupttitel: 28pt, Großbuchstaben, fett
#let title-size = 28pt
// Untertitel: 18pt
#let subtitle-size = 18pt
// Folienüberschriften: 20pt, Großbuchstaben, fett
#let slide-header-size = 20pt
// Unter-Überschriften (Subheadlines): 14pt, Großbuchstaben
#let subheader-size = 14pt
// Fließtext: 18pt
#let body-size = 18pt
// Aufzählung ab 2. Ebene: 16pt
#let nested-list-size = 16pt
// Kopf- und Fußzeile: 12pt
#let header-footer-size = 12pt
// Seitenzahl: 9pt, Rot
#let page-number-size = 9pt
// Datumsangabe: 16pt
#let date-size = 16pt
